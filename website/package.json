{
  "name": "website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "build": "npm run clear && npm run generate-api-docs && npm run setup-docsify",
    "clear": "rimraf dist && mkdir -p dist",
    "serve": "npx serve ./dist",
    "generate-api-docs": "node scripts/generate-api-docs.js",
    "setup-docsify": "node scripts/setup-docsify.js",
    "preview": "npm run build && npm run serve",
    "prepare-deploy": "npm run build",
    "deploy": "gh-pages -d dist -b gh-pages",
    "test:links": "node scripts/tests/run-link-tests.js"
  },
  "devDependencies": {
    "docsify-cli": "^4.4.4",
    "gh-pages": "^6.3.0",
    "glob": "^10.3.10",
    "rimraf": "^5.0.5",
    "typedoc": "^0.25.9",
    "typedoc-plugin-markdown": "^3.17.1",
    "typescript": "~5.6.2",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18.0"
  }
}