{
  "name": "website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "build": "npm run generate-api-docs",
    "clear": "rimraf docs/api-reference",
    "serve": "npx docsify-cli serve ../docs",
    "generate-api-docs": "node scripts/generate-api-docs.js",
    "setup-docsify": "node scripts/setup-docsify.js",
    "preview": "npm run build && npm run setup-docsify && npm run serve",
    "prepare-deploy": "npm run build && npm run setup-docsify"
  },
  "devDependencies": {
    "docsify-cli": "^4.4.4",
    "gh-pages": "^6.3.0",
    "glob": "^10.3.10",
    "rimraf": "^5.0.5",
    "typedoc": "^0.25.9",
    "typedoc-plugin-markdown": "^3.17.1",
    "typescript": "~5.6.2"
  },
  "engines": {
    "node": ">=18.0"
  }
}